# Copy this file to .env and fill in your own values.
# Never commit .env to git.

# Google OAuth credentials (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# HappyScribe API key (from happyscribe.com > Account > API)
HAPPYSCRIBE_API_KEY=your_happyscribe_api_key_here

# Zapier webhook URL for sending emails via Outlook
ZAPIER_OUTLOOK_WEBHOOK=https://hooks.zapier.com/hooks/catch/your_webhook_id_here

# The sender email address used in Outlook
OUTLOOK_SENDER=your.email@outlook.com

# Google Drive File ID of your team roster spreadsheet
TEAM_SHEET_ID=your_google_sheet_file_id_here

# SMTP settings for sending meeting minutes directly (optional — can use Zapier instead)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your.email@yourcompany.com
SMTP_PASS=your_smtp_password_here
